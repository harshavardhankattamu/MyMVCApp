@using Microsoft.AspNetCore.Http
@{
    var uname = Context.Session.GetString("uname");
}
<html>
    <head>
      <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM" crossorigin="anonymous"></script>
     </head>




<body style="
    background-image:url('/images/AussiePizza.jpg');
    background-size:cover;
    background-repeat:no-repeat;
    background-position:center;
    min-height:100vh;
    image-rendering: -webkit-optimize-contrast;
    image-rendering: crisp-edges;">

  
      <div class="container">  
         <nav class = "navbar bg-dark navbar-dark">  
        <a class = "navbar-brand" asp-action="Menu"> Menu </a>  
        <ul class = "nav">  
            
            @if(uname==null)
            {
                    <li class="nav-item">
                        <a class="nav-link" asp-action="Login"> Login </a>
                    </li>
           
            }
         else{
        
        <li class = "nav-item">  
        <a class = "nav-link" asp-action="Logout"> Logout </a>  
        </li> 
         }
        
        <li class = "nav-item">  
        <a class = "nav-link"asp-action="Cart"> Cart </a>  
        </li>  
        <li class = "nav-item">  
        <a class = "nav-link" asp-action="Contact"> Contact </a>  
        </li>  
        </ul>
            @if (uname == null)
            {
                <h6 class= "navbar-text text-light" > Welcome Guest </h6 >

            }
            else
            {
                <h6 class="navbar-text text-light"> Welcome @uname </h6>

            }
        <form class="d-flex justify-content-end" asp-for="Search" asp-controller="MyPizza">  
        <input class="form-control me-2" type="text" placeholder="Search">  
        <button class="btn btn-success" type="button">Search</button>
                
        </form>  
        </nav> 
</div>
 <div>
        @RenderBody()
    </div>
</body>

</html>







































































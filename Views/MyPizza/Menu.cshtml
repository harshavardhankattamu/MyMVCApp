@model List< My_MVCApp.Models.Pizza>;
<div class="row g-4">
    @foreach (var i in Model)
    {
        <div class="col-md-3">
           
            <div class="card h-100 shadow-sm border-0 rounded-3 text-center">

               
                <div class="p-3">
                    <img src="@i.Pimage"
                         class="card-img-top img-fluid rounded"
                         style="height: 250px; object-fit: cover;"
                         alt="@i.Pizzaname" />
                </div>

                <div class="card-body d-flex flex-column">
                    <h5 class="card-title fw-bold">@i.Pizzaname</h5>
                    <p class="card-text text-muted small">@i.Description</p>
                    <div class="card-text fs-5 text-success fw-bold mt-auto mb-3">
                        @string.Format("{0:C}", i.Price)
                    </div>

                    <a asp-action="Cart"
                       asp-route-pid="@i.Pizzaid"
                       class="btn btn-outline-info rounded-pill w-100 mt-auto">
                        Order Now
                    </a>
                </div>
            </div>
        </div>
    }
</div>
